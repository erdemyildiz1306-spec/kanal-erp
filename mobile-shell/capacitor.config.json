{
  "appId": "com.kanalerp.app",
  "appName": "KanalERP",
  "webDir": "out",
  "server": {
    "url": "https://erp-stok.vercel.app",
    "cleartext": false,
    "androidScheme": "https",
    "allowNavigation": ["erp-stok.vercel.app", "*.vercel.app"]
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#f4f2ee",
    "webContentsDebuggingEnabled": false,
    "captureInput": true,
    "useLegacyBridge": false
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "androidSplashResourceName": "splash",
      "backgroundColor": "#f4f2ee",
      "showSpinner": false
    }
  }
}
