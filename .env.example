# Canlı site HTTPS adresi — Trendyol görsel yayımlama (boşsa erp-stok.vercel.app kullanılır)
NEXT_PUBLIC_APP_URL=https://erp-stok.vercel.app

# Vercel Blob — canlı görsel yükleme (Vercel Storage > Blob store oluşturunca otomatik eklenir)
# BLOB_READ_WRITE_TOKEN=

# Trendyol E-Faturam — Ayarlar > Trendyol sekmesinden de yapılandırılır
# https://developers.trendyolefaturam.com/

# MongoDB — kalıcı veri için dizge veya yerel Mongo (ör. docker compose up -d)
# Boş veya memory: geliştirmede .data/mongo-dev altında dosya tabanlı yedek Mongo kullanılır.
# localhost:27017 kapalıysa otomatik aynı yedek veritabanına düşer (Trendyol ayarları korunur).
# MONGODB_URI=
# MONGODB_URI=memory
MONGODB_URI=mongodb://127.0.0.1:27017/kanal-erp

# Oturum imzası — üretimde mutlaka güçlü rastgele değer (AUTH_SESSION_SECRET)
# AUTH_SESSION_SECRET=uzun-rastgele-dize

# Root panel — virgülle ayrılmış platform yönetici e-postaları (girişte /root erişimi)
# ROOT_ADMIN_EMAILS=admin@example.com
# İlk kurulumda Atlas'ta kullanıcı yoksa giriş için (canlıda bir kez tanımlayın)
# ROOT_ADMIN_PASSWORD=

# Lisans ödemesi — IBAN / havale (sanal POS yok)
# PLATFORM_BANK_NAME=Ziraat Bankası
# PLATFORM_ACCOUNT_HOLDER=Kanal ERP Ltd. Şti.
# PLATFORM_IBAN=TR00...
# PLATFORM_PAYMENT_DESCRIPTION=Kanal ERP lisans — {tenantId}
# Standart paket (Trendyol E-Faturam hariç)
# LICENSE_STANDARD_MONTHLY=990
# LICENSE_STANDARD_YEARLY=9900
# E-Faturam paketi (Standart + Trendyol E-Faturam)
# LICENSE_EFATURA_MONTHLY=1490
# LICENSE_EFATURA_YEARLY=14900

# Şifre sıfırlama e-postası (opsiyonel — Resend)
# RESEND_API_KEY=re_...
# MAIL_FROM=Kanal ERP <noreply@sizin-domain.com>

# Trendyol test — .env.local içinde kullanın; sunucuyu durdurup yeniden başlatın
# Yalnızca 2 örnek ürün yükler; canlı API çağrısı yapmaz (API anahtarı gerekmez)
# TRENDYOL_SYNC_ONLY_MOCK=true
# API boş dönünce veya hata sonrası yedek örnek veri: true / 1 / yes
# TRENDYOL_ALLOW_SYNC_MOCK=true
# Geliştirmede Trendyol sipariş sync mock (prod'da kapalı)
# TRENDYOL_ALLOW_ORDER_SYNC_MOCK=true
# Önce eski sapigw ürün listesini dene (ürünler yalnız orada görünen satıcılar için)
# TRENDYOL_PRODUCT_LIST_LEGACY_FIRST=true

# Mağaza webhook doğrulama — POST /api/orders/webhook header: x-webhook-secret
# STORE_WEBHOOK_SECRET=
